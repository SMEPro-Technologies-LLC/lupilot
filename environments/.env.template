# Environment Variables Template
# Copy this file to .env.staging, .env.production, or .env.local
# DO NOT COMMIT THE COPIED FILE TO GIT

# ============================================================
# ORGANIZATION
# ============================================================
ORG_NAME=LamarUniversity
PROJECT_PREFIX=lamar-ios
DOMAIN=ios.lamar.edu

# ============================================================
# GCP CONFIGURATION
# ============================================================
GCP_REGION=us-central1
GCP_PROJECT_SHARED=lamar-ios-shared
GCP_PROJECT_STAGING=lamar-ios-staging
GCP_PROJECT_PRODUCTION=lamar-ios-prod
GCP_BILLING_ACCOUNT=XXXXXX-XXXXXX-XXXXXX

# ============================================================
# GITHUB / CI-CD
# ============================================================
GITHUB_ORG=LamarUniversity
GITHUB_REPO=ios-plus
GITHUB_WORKLOAD_IDENTITY_PROVIDER=projects/PROJECT_NUMBER/locations/global/workloadIdentityPools/POOL/providers/PROVIDER
GITHUB_SERVICE_ACCOUNT=github-actions@PROJECT_ID.iam.gserviceaccount.com

# ============================================================
# CONTAINER REGISTRY
# ============================================================
REGISTRY=us-central1-docker.pkg.dev/${GCP_PROJECT_SHARED}/artifact-registry
IMAGE_TAG=latest

# ============================================================
# DATABASE
# ============================================================
DB_HOST=10.0.0.3
DB_PORT=5432
DB_NAME=ios_plus
DB_USER=ios_admin
# DB_PASSWORD is managed by Secret Manager / Vault
DB_SSL_MODE=require
DB_CONNECTION_NAME=${GCP_PROJECT_SHARED}:us-central1:ios-plus-db

# ============================================================
# REDIS / CACHE
# ============================================================
REDIS_HOST=10.0.0.4
REDIS_PORT=6379
# REDIS_PASSWORD is managed by Secret Manager / Vault
REDIS_CONNECTION_NAME=${GCP_PROJECT_SHARED}:us-central1:ios-plus-redis

# ============================================================
# AUTHENTICATION / IDENTITY
# ============================================================
IDP_TYPE=saml
IDP_METADATA_URL=https://sso.lamar.edu/metadata.xml
IDP_ENTITY_ID=https://ios.lamar.edu/sp
IDP_SSO_URL=https://sso.lamar.edu/idp/profile/SAML2/Redirect/SSO
IDP_SLO_URL=https://sso.lamar.edu/idp/profile/SAML2/Redirect/SLO
IDP_CERTIFICATE_PATH=/secrets/idp-cert.pem
# JWT_SIGNING_KEY is managed by Secret Manager / Vault
JWT_ALGORITHM=RS256
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=86400

# ============================================================
# TLS / CERTIFICATES
# ============================================================
TLS_CERT_SOURCE=letsencrypt
TLS_EMAIL=admin@lamar.edu
TLS_ACME_SERVER=https://acme-v02.api.letsencrypt.org/directory
# TLS_CERT_PATH and TLS_KEY_PATH for purchased certs
TLS_CERT_PATH=/secrets/tls.crt
TLS_KEY_PATH=/secrets/tls.key

# ============================================================
# MONITORING & ALERTING
# ============================================================
GRAFANA_ADMIN_PASSWORD_PATH=/secrets/grafana-admin-password
PROMETHEUS_RETENTION=30d
LOKI_RETENTION=7d
ALERTMANAGER_SLACK_WEBHOOK_PATH=/secrets/slack-webhook-url
ALERTMANAGER_EMAIL_TO=ops@lamar.edu
SENTRY_DSN_PATH=/secrets/sentry-dsn

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout
ENABLE_ACCESS_LOG=true
ENABLE_AUDIT_LOG=true

# ============================================================
# SECRETS MANAGER
# ============================================================
SECRETS_MANAGER=gcp
# VAULT_ADDR=https://vault.lamar.edu:8200
# VAULT_ROLE=ios-plus
# VAULT_MOUNT_PATH=secret

# ============================================================
# API CONNECTORS
# ============================================================
BANNER_API_URL=https://banner.lamar.edu/api
BANNER_API_CREDENTIALS_PATH=/secrets/banner-api-credentials

BLACKBOARD_API_URL=https://blackboard.lamar.edu/learn/api/public/v3
BLACKBOARD_API_KEY_PATH=/secrets/blackboard-api-key

# ============================================================
# AI / ML SERVICES
# ============================================================
ANTHROPIC_API_KEY_PATH=/secrets/anthropic-api-key
OPENAI_API_KEY_PATH=/secrets/openai-api-key
FIRECRAWL_API_KEY_PATH=/secrets/firecrawl-api-key
ML_MODEL_REGISTRY=gs://${GCP_PROJECT_SHARED}-ml-models
MLFLOW_TRACKING_URI=http://mlflow.monitoring.svc.cluster.local:5000

# ============================================================
# EMAIL / NOTIFICATIONS
# ============================================================
SMTP_HOST=smtp.lamar.edu
SMTP_PORT=587
SMTP_USER=noreply@lamar.edu
SMTP_PASSWORD_PATH=/secrets/smtp-password
SMTP_TLS=true

SENDGRID_API_KEY_PATH=/secrets/sendgrid-api-key
NOTIFICATION_FROM=noreply@lamar.edu

# ============================================================
# TRACE CHAIN / BLOCKCHAIN
# ============================================================
TRACE_CHAIN_ENABLED=false
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
SMART_CONTRACT_ADDRESS=0x...
TRACE_CHAIN_PRIVATE_KEY_PATH=/secrets/trace-chain-private-key

# ============================================================
# FEATURE FLAGS
# ============================================================
ENABLE_ML_JOBS=false
ENABLE_KAFKA=false
ENABLE_BLOCKCHAIN=false
ENABLE_ADVANCED_GOVERNANCE=false
ENABLE_FERPA_AUDIT_AUTO=false

# ============================================================
# PERFORMANCE & SCALING
# ============================================================
API_RATE_LIMIT_PER_MINUTE=100
API_BURST_LIMIT=20
CACHE_TTL_SECONDS=300
DB_POOL_SIZE=20
DB_POOL_TIMEOUT=30
WORKER_CONCURRENCY=4

# ============================================================
# ENVIRONMENT-SPECIFIC (override in .env.staging / .env.production)
# ============================================================
# ENVIRONMENT=development | staging | production
# REPLICAS=2
# CPU_REQUEST=250m
# CPU_LIMIT=1000m
# MEMORY_REQUEST=512Mi
# MEMORY_LIMIT=2Gi
